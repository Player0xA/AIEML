# emltriage Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# AI Providers (optional - only if using cloud AI)
# ============================================================================

# OpenAI API Key (for GPT-4, GPT-3.5)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (for Claude)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Ollama Configuration (default - local AI)
# Ollama runs locally, no API key needed
# Just install from: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# CTI Providers (optional - only for online threat intel)
# ============================================================================

# VirusTotal API Key
# Get from: https://www.virustotal.com/gui/user/signup
# VIRUSTOTAL_API_KEY=your-vt-api-key-here

# AbuseIPDB API Key
# Get from: https://www.abuseipdb.com/register
# ABUSEIPDB_API_KEY=your-abuseipdb-key-here

# ============================================================================
# Default Settings
# ============================================================================

# Default AI provider (ollama, openai, anthropic)
EMLTRIAGE_AI_PROVIDER=ollama

# Default model (provider-specific)
# EMLTRIAGE_AI_MODEL=llama3.1

# ============================================================================
# Notes
# ============================================================================

# This tool works 100% offline without any API keys!
# Only set keys for providers you want to use.

# For offline-only usage:
# - Don't set any API keys
# - Use --offline flag with all commands
# - Use local watchlists for threat intel
